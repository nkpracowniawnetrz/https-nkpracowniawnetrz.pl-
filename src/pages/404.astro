---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
---
<Layout title="404 — Strona nie odnaleziona | NK Pracownia Wnętrz" description="Strona, której szukasz, nie została odnaleziona.">
  <Navigation />
  <main class="pt-32 pb-24 flex-1 flex items-center justify-center">
    <div class="max-w-xl mx-auto px-6 text-center">
      <p class="text-beige text-sm tracking-[0.3em] uppercase mb-6">Błąd</p>
      <h1 class="text-8xl md:text-9xl font-light tracking-wider text-white/90 mb-6">404</h1>
      <h2 class="text-xl md:text-2xl font-light text-white mb-4">Strona nie została odnaleziona</h2>
      <p class="text-white/50 font-light text-sm leading-relaxed mb-12">
        Przepraszamy, ale strona której szukasz nie istnieje lub została przeniesiona.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-beige text-black px-8 py-3 text-sm tracking-wider uppercase hover:bg-beige-light transition-colors">
          Wróć na stronę główną
        </a>
        <a href="/portfolio" class="border border-white/20 text-white px-8 py-3 text-sm tracking-wider uppercase hover:border-beige hover:text-beige transition-colors">
          Zobacz portfolio
        </a>
      </div>
    </div>
  </main>
  <Footer />
</Layout>
