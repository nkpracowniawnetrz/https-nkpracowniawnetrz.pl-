---
import ScrollReveal from "./ScrollReveal.astro";
import { projects } from "../data/projects";

const featured = projects.slice(0, 6);
---

<section id="portfolio" class="py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <ScrollReveal>
      <div class="text-center mb-16">
        <p class="text-beige text-sm tracking-[0.3em] uppercase mb-4">Portfolio</p>
        <h2 class="text-3xl md:text-4xl font-light">Moje realizacje</h2>
      </div>
    </ScrollReveal>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map((project, index) => (
        <ScrollReveal delay={index * 100}>
          <a href={`/portfolio/${project.id}`} class="group relative aspect-[4/3] overflow-hidden bg-surface block">
            <img src={project.thumbnail} alt={project.title} loading="lazy" decoding="async" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/0 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-end">
              <div class="p-6">
                <p class="text-beige text-xs tracking-wider uppercase mb-1">{project.category}</p>
                <h3 class="text-lg font-light">{project.title}</h3>
              </div>
            </div>
          </a>
        </ScrollReveal>
      ))}
    </div>

    <ScrollReveal delay={300}>
      <div class="text-center mt-12">
        <a href="/portfolio" class="inline-block border border-beige text-beige px-8 py-3.5 text-sm tracking-wider uppercase hover:bg-beige hover:text-black transition-all duration-300">
          Zobacz wszystkie realizacje
        </a>
      </div>
    </ScrollReveal>
  </div>
</section>
