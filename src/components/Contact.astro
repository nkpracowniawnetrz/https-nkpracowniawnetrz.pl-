---
import ScrollReveal from "./ScrollReveal.astro";
---

<section id="kontakt" class="py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <ScrollReveal>
      <div class="text-center mb-16">
        <p class="text-beige text-sm tracking-[0.3em] uppercase mb-4">Kontakt</p>
        <h2 class="text-3xl md:text-4xl font-light">Porozmawiajmy o Twoim projekcie</h2>
      </div>
    </ScrollReveal>

    <div class="grid md:grid-cols-2 gap-16 max-w-5xl mx-auto">
      <ScrollReveal>
        <div class="space-y-10">
          <div>
            <h3 class="text-lg font-light mb-8 tracking-wide">Dane kontaktowe</h3>
            <div class="space-y-6">
              <div class="flex items-center gap-5 group">
                <div class="w-12 h-12 border border-white/10 group-hover:border-beige/30 flex items-center justify-center transition-colors">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-beige"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                </div>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Telefon</p>
                  <a href="tel:+48725360335" class="text-white/70 font-light hover:text-beige transition-colors">+48 725 360 335</a>
                </div>
              </div>
              <div class="flex items-center gap-5 group">
                <div class="w-12 h-12 border border-white/10 group-hover:border-beige/30 flex items-center justify-center transition-colors">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-beige"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Email</p>
                  <a href="mailto:nkpracowniawnetrz@gmail.com" class="text-white/70 font-light hover:text-beige transition-colors">nkpracowniawnetrz@gmail.com</a>
                </div>
              </div>
              <div class="flex items-center gap-5 group">
                <div class="w-12 h-12 border border-white/10 group-hover:border-beige/30 flex items-center justify-center transition-colors">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-beige"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                </div>
                <div>
                  <p class="text-xs text-white/50 uppercase tracking-wider mb-1">Lokalizacja</p>
                  <span class="text-white/70 font-light">Tomaszów Mazowiecki i okolice</span>
                </div>
              </div>
            </div>
          </div>
          <div>
            <h3 class="text-lg font-light mb-4 tracking-wide">Social media</h3>
            <div class="flex gap-3">
              <a href="https://www.instagram.com/nk.pracowniawnetrz/" target="_blank" rel="noopener noreferrer" class="w-12 h-12 border border-white/10 flex items-center justify-center hover:border-beige hover:text-beige transition-all duration-300" aria-label="Instagram">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
              </a>
              <a href="https://www.facebook.com/profile.php?id=61588354151901" target="_blank" rel="noopener noreferrer" class="w-12 h-12 border border-white/10 flex items-center justify-center hover:border-beige hover:text-beige transition-all duration-300" aria-label="Facebook">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3V2z"/></svg>
              </a>
            </div>
          </div>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={200}>
        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-8">
          <input type="hidden" name="access_key" value="50f1b247-fa6d-40e5-8567-3a8896b0d450" />
          <input type="hidden" name="subject" value="Nowa wiadomość ze strony nkpracowniawnetrz.pl" />
          <input type="hidden" name="from_name" value="NK Pracownia Wnętrz - Formularz" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />
          <div>
            <label for="field-name" class="text-xs text-white/60 uppercase tracking-wider mb-2 block">Imię i nazwisko</label>
            <input type="text" id="field-name" name="name" required maxlength="100" class="w-full bg-transparent border-b border-white/15 py-3 text-sm text-white focus:border-beige focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="field-email" class="text-xs text-white/60 uppercase tracking-wider mb-2 block">Email</label>
            <input type="email" id="field-email" name="email" required maxlength="254" class="w-full bg-transparent border-b border-white/15 py-3 text-sm text-white focus:border-beige focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="field-phone" class="text-xs text-white/60 uppercase tracking-wider mb-2 block">Telefon</label>
            <input type="tel" id="field-phone" name="phone" maxlength="20" pattern="[\d\s\+\-\(\)]{0,20}" class="w-full bg-transparent border-b border-white/15 py-3 text-sm text-white focus:border-beige focus:outline-none transition-colors" />
          </div>
          <div>
            <label for="field-message" class="text-xs text-white/60 uppercase tracking-wider mb-2 block">Wiadomość</label>
            <textarea id="field-message" name="message" required rows="4" maxlength="5000" class="w-full bg-transparent border-b border-white/15 py-3 text-sm text-white focus:border-beige focus:outline-none transition-colors resize-none"></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="privacy-consent" name="privacy_consent" required class="mt-1 accent-[#c9a96e] cursor-pointer" />
            <label for="privacy-consent" class="text-xs text-white/50 font-light leading-relaxed cursor-pointer">
              Zapoznałam/em się z <a href="/polityka-prywatnosci" target="_blank" class="text-beige underline hover:text-beige-light">polityką prywatności</a> i wyrażam zgodę na przetwarzanie moich danych osobowych w celu odpowiedzi na zapytanie.
            </label>
          </div>
          <button type="submit" class="w-full bg-beige text-black py-4 text-sm tracking-wider uppercase hover:bg-beige-light transition-all duration-300 cursor-pointer">
            Wyślij wiadomość
          </button>
        </form>
      </ScrollReveal>
    </div>
  </div>
</section>

<script>
  const formSubmits: number[] = [];
  document.getElementById("contact-form")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const btn = form.querySelector("button[type='submit']") as HTMLButtonElement;
    const originalText = btn.textContent;

    const now = Date.now();
    const recentSubmits = formSubmits.filter(t => now - t < 300000);
    if (recentSubmits.length >= 3) {
      btn.textContent = "Zbyt wiele prób — spróbuj za chwilę";
      setTimeout(() => { btn.textContent = originalText; }, 4000);
      return;
    }

    btn.textContent = "Wysyłanie...";
    btn.disabled = true;

    try {
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: new FormData(form),
      });
      const data = await res.json();
      if (data.success) {
        formSubmits.push(now);
        btn.textContent = "Wysłano!";
        btn.classList.remove("bg-beige", "text-black");
        btn.classList.add("bg-green-600", "text-white");
        form.reset();
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled = false;
          btn.classList.remove("bg-green-600", "text-white");
          btn.classList.add("bg-beige", "text-black");
        }, 3000);
      } else {
        throw new Error();
      }
    } catch {
      btn.textContent = "Błąd — spróbuj ponownie";
      btn.disabled = false;
      setTimeout(() => { btn.textContent = originalText; }, 3000);
    }
  });
</script>
